# =========================================================
# ARQUIVO DE EXEMPLO PARA CONFIGURAÇÃO DE CREDENCIAIS
# =========================================================
# Renomeie este arquivo para ".env" e preencha as variáveis
# com as suas próprias chaves e acessos para o projeto rodar.
# =========================================================

# Chave de API da plataforma Groq (usada para o modelo Llama 3)
# Adquira gratuitamente em: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_da_groq_aqui

# =========================================================
# Integrações de Infraestrutura (ZABBIX)
# =========================================================

# URL principal da interface web da sua instância Zabbix
ZABBIX_URL=http://192.168.X.X/zabbix

# Token de acesso da API do Zabbix (Gerado via Administração -> Usuários)
ZABBIX_TOKEN=seu_token_de_api_do_zabbix_aqui
